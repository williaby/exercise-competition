{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":preserveSemverRanges"
  ],
  "timezone": "America/New_York",
  "schedule": [
    "after 10pm every weekday",
    "before 5am every weekday",
    "every weekend"
  ],
  "labels": [
    "dependencies",
    "automated"
  ],
  "assignees": [
    "williaby"
  ],
  "reviewers": [
    "williaby"
  ],
  "packageRules": [
    {
      "description": "Auto-merge GitHub Actions minor/patch updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash"
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "commitMessageTopic": "GitHub Actions"
    },
    {
      "description": "Pin GitHub Actions to commit SHA",
      "matchManagers": ["github-actions"],
      "pinDigests": true
    },
    {
      "description": "Refresh SHA pins for org reusable workflows that float the v1 tag. pinDigests (rule 3) handles the initial pin; this rule groups the digest-refresh PRs for ByronWilliamsCPA/.github and williaby/.github so they don't generate noise as individual updates.",
      "matchManagers": ["github-actions"],
      "matchPackageNames": ["/ByronWilliamsCPA\\/\\.github/", "/williaby\\/\\.github/"],
      "groupName": "Org workflow SHA pins"
    },
    {
      "description": "Name Python dependency PRs by package. pyproject.toml (PEP 621, uv-managed) is the single Python dependency manifest, so only the pep621 manager is matched.",
      "matchManagers": ["pep621"],
      "groupName": "Python dep {{depName}}",
      "commitMessageTopic": "Python dependency {{depName}}"
    },
    {
      "description": "Disable automated Python version (requires-python) updates; bump manually when ready",
      "matchDepTypes": ["requires-python"],
      "enabled": false,
      "labels": ["dependencies", "python-version", "breaking-change"]
    },
    {
      "description": "Group frontend npm dependencies (frontend/package.json) by package",
      "matchManagers": ["npm"],
      "groupName": "Frontend npm {{depName}}",
      "commitMessageTopic": "Frontend dependency {{depName}}"
    },
    {
      "description": "Group Docker base image updates across Dockerfile and docker-compose",
      "matchManagers": ["dockerfile", "docker-compose"],
      "groupName": "Docker base images",
      "commitMessageTopic": "Docker image {{depName}}"
    }
  ],
  "enabledManagers": [
    "pep621",
    "npm",
    "dockerfile",
    "docker-compose",
    "github-actions",
    "pre-commit"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on monday"],
    "commitMessageAction": "Refresh"
  },
  "separateMajorMinor": true,
  "separateMinorPatch": false,
  "prConcurrentLimit": 5,
  "rebaseWhen": "conflicted",
  "semanticCommits": "enabled",
  "commitMessagePrefix": "chore(deps):",
  "rangeStrategy": "bump",
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "assignees": ["williaby"],
    "reviewers": ["williaby"]
  },
  "osvVulnerabilityAlerts": true
}
