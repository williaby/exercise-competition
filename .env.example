# ============================================================================
# Exercise Competition - Environment Configuration
# ============================================================================
# Copy to .env and fill in values: cp .env.example .env

# ============================================================================
# Application Settings
# ============================================================================
ENVIRONMENT=development
APP_PORT=8000
LOG_LEVEL=INFO

# App settings (prefix: EXERCISE_COMPETITION_)
EXERCISE_COMPETITION_LOG_LEVEL=INFO
EXERCISE_COMPETITION_JSON_LOGS=false
EXERCISE_COMPETITION_DATABASE_URL=sqlite:///data/competition.db

# ============================================================================
# Vultr VPS Deployment
# ============================================================================
VULTR_API_KEY=your-vultr-api-key-here
VULTR_VPS_IP=your-vps-ip-here
VULTR_SSH_USER=root
VULTR_SSH_KEY_PATH=~/.ssh/id_ed25519

# ============================================================================
# Sentry Error Tracking (Optional)
# ============================================================================
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project-id>
# SENTRY_ENVIRONMENT=${ENVIRONMENT:-development}
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ============================================================================
# Docker Configuration
# ============================================================================
VERSION=latest
